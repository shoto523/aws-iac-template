project_name = "my-app"
aws_region   = "ap-northeast-1"

# ネットワーク（AWSコンソールまたはAWS CLIで確認して設定）
vpc_id                = "vpc-xxxxxxxx"
public_subnet_ids     = ["subnet-aaa", "subnet-bbb"]  # ALB配置先（複数）
private_subnet_ids    = ["subnet-ccc", "subnet-ddd"]  # ECSタスク配置先（複数）
alb_security_group_id = "sg-xxxxxxxx"
ecs_security_group_id = "sg-yyyyyyyy"

# コンテナ
container_name     = "my-app"
container_port     = 80
ecr_repository_url = "123456789012.dkr.ecr.ap-northeast-1.amazonaws.com/my-app"  # aws-cicdの出力値
